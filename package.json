{
  "name": "astro-navfolio",
  "type": "module",
  "version": "0.2.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "fonts:ui": "bun scripts/fonts/subset-ui-font.ts",
    "build": "bun run fonts:ui && astro build && pagefind --site dist --output-subdir pagefind --root-selector main --exclude-selectors \"[data-pagefind-ignore]\"",
    "preview": "astro preview",
    "astro": "astro",
    "post:new": "bun scripts/new-content.ts blog",
    "vibe:new": "bun scripts/new-content.ts vibe",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "bun run lint && prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@expressive-code/plugin-collapsible-sections": "^0.43.1",
    "@expressive-code/plugin-line-numbers": "^0.43.1",
    "@fontsource/maple-mono": "^5.2.6",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.7",
    "astro-expressive-code": "^0.43.1",
    "lucide-astro": "^0.556.0",
    "sharp": "^0.35.1",
    "smol-toml": "^1.6.1",
    "tailwindcss": "^4.3.1",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.9.10"
  },
  "devDependencies": {
    "@types/three": "^0.184.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint-plugin-deprecation": "^3.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*": "bun run format:check"
  }
}
